{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/explorer/**",
              "components/ledger/**",
              "ui_kits/gumption-hub/**",
              "ui_kits/gumptionchain-explorer/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Righteous))/i]",
        "message": "Font not provided by the design system. Available: Inter, Righteous."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|outline-gold|stone)$/]",
        "message": "<Button> variant must be one of 'gold' | 'outline-gold' | 'stone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|title|tagline|teaser|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: kicker, title, tagline, teaser, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Grit'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|mono|title|key|ref|className|style|children)$/]",
        "message": "<Grit> doesn't accept that prop. Declared props: size, mono, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='GritMint'] > JSXAttribute > JSXIdentifier[name!=/^(?:amount|size|showAmount|label|replayOnClick|animate|key|ref|className|style|children)$/]",
        "message": "<GritMint> doesn't accept that prop. Declared props: amount, size, showAmount, label, replayOnClick, animate."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|animate|title|key|ref|className|style|children)$/]",
        "message": "<HeroLogo> doesn't accept that prop. Declared props: size, animate, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|key|ref|className|style|children)$/]",
        "message": "<KindLabel> doesn't accept that prop. Declared props: kind, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindLabel'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:support|opposition)$/]",
        "message": "<KindLabel> kind must be one of 'support' | 'opposition'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LedgerRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:subject|support|opposition|href|key|ref|className|style|children)$/]",
        "message": "<LedgerRow> doesn't accept that prop. Declared props: subject, support, opposition, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='NetStance'] > JSXAttribute > JSXIdentifier[name!=/^(?:opposition|support|key|ref|className|style|children)$/]",
        "message": "<NetStance> doesn't accept that prop. Declared props: opposition, support."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutflowBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|key|ref|className|style|children)$/]",
        "message": "<OutflowBadge> doesn't accept that prop. Declared props: kind."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutflowBadge'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:opposition|support|rescind|transfer)$/]",
        "message": "<OutflowBadge> kind must be one of 'opposition' | 'support' | 'rescind' | 'transfer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute > JSXIdentifier[name!=/^(?:verified|pulsing|size|key|ref|className|style|children)$/]",
        "message": "<Seal> doesn't accept that prop. Declared props: verified, pulsing, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|subject|amount|signer|age|key|ref|className|style|children)$/]",
        "message": "<TickerItem> doesn't accept that prop. Declared props: kind, subject, amount, signer, age."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerItem'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:support|opposition)$/]",
        "message": "<TickerItem> kind must be one of 'support' | 'opposition'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WordmarkLockup'] > JSXAttribute > JSXIdentifier[name!=/^(?:orientation|size|wordmarkSize|animate|wordmark|key|ref|className|style|children)$/]",
        "message": "<WordmarkLockup> doesn't accept that prop. Declared props: orientation, size, wordmarkSize, animate, wordmark."
      },
      {
        "selector": "JSXOpeningElement[name.name='WordmarkLockup'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|stacked)$/]",
        "message": "<WordmarkLockup> orientation must be one of 'horizontal' | 'stacked'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
